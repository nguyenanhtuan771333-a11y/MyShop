@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Đăng nhập</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: url('/images/login_bg.jpg') no-repeat center center fixed;
            background-size: cover;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .login-box {
            background: rgba(255,255,255,0.95);
            padding: 40px 35px;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.4);
            width: 100%;
            max-width: 400px;
            backdrop-filter: blur(5px);
            border: 1px solid rgba(255,255,255,0.3);
        }

            .login-box h2 {
                color: #1a1a2e;
                text-align: center;
                margin-bottom: 25px;
                font-size: 2em;
                font-weight: 700;
            }

            .login-box input {
                width: 100%;
                padding: 14px 16px;
                margin: 10px 0;
                border-radius: 12px;
                border: 1px solid #ddd;
                background: #f8f9fa;
                color: #1a1a2e;
                font-size: 1em;
                box-sizing: border-box;
                transition: 0.3s;
            }

                .login-box input:focus {
                    outline: none;
                    border-color: #007bff;
                    box-shadow: 0 0 0 3px rgba(0,123,255,0.2);
                }

            .login-box button {
                width: 100%;
                padding: 14px;
                border-radius: 12px;
                border: none;
                background: #007bff;
                color: white;
                font-size: 1.2em;
                font-weight: bold;
                cursor: pointer;
                transition: 0.3s;
                animation: blink 1.2s infinite alternate;
            }

        @@keyframes blink {
            0% {
                background: #007bff;
                box-shadow: 0 0 10px rgba(0,123,255,0.3);
            }

            100% {
                background: #0056b3;
                box-shadow: 0 0 25px rgba(0,123,255,0.6);
            }
        }

        .login-box button:hover {
            transform: scale(1.02);
        }

        .login-box .links {
            display: flex;
            justify-content: space-between;
            margin: 18px 0 10px 0;
            color: #333;
        }

            .login-box .links a {
                color: #007bff;
                text-decoration: none;
                font-size: 0.95em;
                transition: 0.3s;
            }

                .login-box .links a:hover {
                    text-decoration: underline;
                }

        .login-box .error {
            color: #dc3545;
            text-align: center;
            margin-top: 12px;
            font-weight: 500;
        }

        .login-box .note {
            color: #555;
            font-size: 0.85em;
            text-align: center;
            margin-top: 18px;
            border-top: 1px solid #eee;
            padding-top: 15px;
            background: #f8f9fa;
            border-radius: 8px;
            padding: 12px;
        }

            .login-box .note strong {
                color: #dc3545;
            }
    </style>
</head>
<body>
    <div class="login-box">
        <h2>🔐 Đăng nhập</h2>
        <form method="post">
            <input type="text" name="username" placeholder="👤 Tên đăng nhập" required />
            <input type="password" name="password" placeholder="🔒 Mật khẩu" required />
            <button type="submit">🚀 Đăng nhập</button>
            <div class="links">
                <a href="/Account/Register">📝 Đăng ký</a>
                <a href="/Account/ForgotPassword">❓ Quên mật khẩu</a>
            </div>
            @if (!string.IsNullOrEmpty(ViewBag.Error))
            {
                <div class="error">❌ @ViewBag.Error</div>
            }
            <div class="note">
                ⚠️ <strong>Lưu ý:</strong> Nếu bạn không đăng nhập được tài khoản cũ, hãy tạo lại tài khoản y hệt.
            </div>
        </form>
    </div>
</body>
</html>